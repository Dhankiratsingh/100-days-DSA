#include <stdio.h>

int canAllocate(int books[], int n, int m, int max_pages) {
    int students_needed = 1;
    int current_sum = 0;
    
    for (int i = 0; i < n; i++) {
        if (current_sum + books[i] > max_pages) {
            students_needed++;
            current_sum = books[i];
            if (students_needed > m) {
                return 0;
            }
        } else {
            current_sum += books[i];
        }
    }
    
    return 1;
}

int allocateBooks(int books[], int n, int m) {
    if (m > n) {
        return -1;
    }

    int low = 0, high = 0;
    for (int i = 0; i < n; i++) {
        high += books[i];
        low = (low < books[i]) ? books[i] : low;
    }

    int result = high;
    
    while (low <= high) {
        int mid = (low + high) / 2;
        
        if (canAllocate(books, n, m, mid)) {
            result = mid;
            high = mid - 1;
        } else {
            low = mid + 1;
        }
    }
    
    return result;
}

int main() {
    int n, m;
    scanf("%d %d", &n, &m);
    
    int books[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &books[i]);
    }
    
    printf("%d\n", allocateBooks(books, n, m));
    
    return 0;
}
