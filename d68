#include <stdio.h>
#include <stdlib.h>

#define MAX 100

typedef struct {
    int items[MAX];
    int front, rear;
} Queue;

void initQueue(Queue* q) {
    q->front = 0;
    q->rear = -1;
}

int isEmpty(Queue* q) {
    return q->front > q->rear;
}

void enqueue(Queue* q, int value) {
    if (q->rear < MAX - 1) {
        q->rear++;
        q->items[q->rear] = value;
    }
}

int dequeue(Queue* q) {
    if (!isEmpty(q)) {
        int val = q->items[q->front];
        q->front++;
        return val;
    }
    return -1;
}

void topologicalSort(int n, int adj[MAX][MAX]) {
    int inDegree[MAX] = {0};
    Queue q;
    initQueue(&q);

    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            if (adj[i][j] != 0)
                inDegree[j]++;

    for (int i = 0; i < n; i++)
        if (inDegree[i] == 0)
            enqueue(&q, i);

    int count = 0;
    while (!isEmpty(&q)) {
        int u = dequeue(&q);
        printf("%d ", u);
        count++;

        for (int v = 0; v < n; v++)
            if (adj[u][v] != 0) {
                inDegree[v]--;
                if (inDegree[v] == 0)
                    enqueue(&q, v);
            }
    }

    if (count != n)
        printf("\nGraph has a cycle!\n");
}

int main() {
    int n;
    scanf("%d", &n);
    int adj[MAX][MAX];
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            scanf("%d", &adj[i][j]);

    topologicalSort(n, adj);

    return 0;
}
