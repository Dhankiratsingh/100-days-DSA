#include <stdio.h>
#include <stdlib.h>

typedef struct {
    int start;
    int end;
} Meeting;

int compareStartTime(const void *a, const void *b) {
    return ((Meeting*)a)->start - ((Meeting*)b)->start;
}

int minMeetingRooms(Meeting meetings[], int n) {
    if (n == 0) return 0;

    // Sort meetings in increasing order of start time
    qsort(meetings, n, sizeof(Meeting), compareStartTime);

    // Min-heap to track the minimum end time of merged meetings
    int *heap = (int*)malloc(n * sizeof(int));
    int heapSize = 0;

    // Add the end time of the first meeting
    heap[heapSize++] = meetings[0].end;

    for (int i = 1; i < n; i++) {
        // If the current meeting starts after the meeting with the earliest end time
        if (meetings[i].start >= heap[0]) {
            // Reuse the room, remove the earliest ending meeting
            heap[0] = heap[--heapSize];
        }

        // Add the current meeting's end time to the heap
        heap[heapSize++] = meetings[i].end;

        // Min-heapify the heap to keep it sorted
        int idx = heapSize - 1;
        while (idx > 0) {
            int parent = (idx - 1) / 2;
            if (heap[parent] <= heap[idx]) break;
            int temp = heap[parent];
            heap[parent] = heap[idx];
            heap[idx] = temp;
            idx = parent;
        }
    }

    // The size of the heap is the number of rooms required
    free(heap);
    return heapSize;
}

int main() {
    int n;
    scanf("%d", &n);
    
    Meeting meetings[n];
    for (int i = 0; i < n; i++) {
        scanf("%d %d", &meetings[i].start, &meetings[i].end);
    }
    
    printf("%d\n", minMeetingRooms(meetings, n));
    
    return 0;
}
