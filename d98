#include <stdio.h>
#include <stdlib.h>

typedef struct {
    int start;
    int end;
} Interval;

int compareStartTime(const void *a, const void *b) {
    return ((Interval*)a)->start - ((Interval*)b)->start;
}

void mergeIntervals(Interval intervals[], int n) {
    if (n <= 0) return;
    
    // Sort intervals by their start time
    qsort(intervals, n, sizeof(Interval), compareStartTime);

    // Initialize the first interval as the current interval to merge
    int index = 0;
    
    for (int i = 1; i < n; i++) {
        // If intervals overlap
        if (intervals[index].end >= intervals[i].start) {
            // Merge the intervals by updating the end time of the current interval
            if (intervals[i].end > intervals[index].end) {
                intervals[index].end = intervals[i].end;
            }
        } else {
            // No overlap, move the current index
            index++;
            intervals[index] = intervals[i];
        }
    }
    
    // Print the merged intervals
    for (int i = 0; i <= index; i++) {
        printf("[%d, %d] ", intervals[i].start, intervals[i].end);
    }
    printf("\n");
}

int main() {
    int n;
    scanf("%d", &n);
    
    Interval intervals[n];
    for (int i = 0; i < n; i++) {
        scanf("%d %d", &intervals[i].start, &intervals[i].end);
    }
    
    mergeIntervals(intervals, n);
    
    return 0;
}
