#include <stdio.h>
#include <limits.h>

#define MAX 1005

int n, m;
int cost[MAX][MAX];
int visited[MAX];
int key[MAX];

int minKey() {
    int min = INT_MAX, min_index = -1;

    for (int v = 1; v <= n; v++) {
        if (!visited[v] && key[v] < min) {
            min = key[v];
            min_index = v;
        }
    }
    return min_index;
}

int primMST() {
    for (int i = 1; i <= n; i++) {
        key[i] = INT_MAX;
        visited[i] = 0;
    }

    key[1] = 0;
    int totalWeight = 0;

    for (int i = 1; i <= n; i++) {
        int u = minKey();
        visited[u] = 1;
        totalWeight += key[u];

        for (int v = 1; v <= n; v++) {
            if (cost[u][v] && !visited[v] && cost[u][v] < key[v]) {
                key[v] = cost[u][v];
            }
        }
    }

    return totalWeight;
}

int main() {
    scanf("%d %d", &n, &m);

    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= n; j++) {
            cost[i][j] = 0;
        }
    }

    for (int i = 0; i < m; i++) {
        int u, v, w;
        scanf("%d %d %d", &u, &v, &w);
        cost[u][v] = w;
        cost[v][u] = w;
    }

    printf("%d\n", primMST());

    return 0;
}
