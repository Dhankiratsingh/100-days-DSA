#include <stdio.h>


int stack[1000], top = -1;

void push(int x) {
    stack[++top] = x;
}

int pop() {
    return stack[top--];
}


int queue[1000], front = 0, rear = -1;

void enqueue(int x) {
    queue[++rear] = x;
}

int dequeue() {
    return queue[front++];
}

int isQueueEmpty() {
    return front > rear;
}

int isStackEmpty() {
    return top == -1;
}

int main() {
    int n;
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        int x;
        scanf("%d", &x);
        enqueue(x);
    }

   
    while (!isQueueEmpty()) {
        push(dequeue());
    }


    while (!isStackEmpty()) {
        enqueue(pop());
    }

    while (!isQueueEmpty()) {
        printf("%d ", dequeue());
    }

    return 0;
}
