#include <stdio.h>

int canPaint(int boards[], int n, int k, int max_time) {
    int painters_needed = 1;
    int current_time = 0;
    
    for (int i = 0; i < n; i++) {
        if (current_time + boards[i] > max_time) {
            painters_needed++;
            current_time = boards[i];
            if (painters_needed > k) {
                return 0;
            }
        } else {
            current_time += boards[i];
        }
    }
    
    return 1;
}

int minTimeToPaintBoards(int boards[], int n, int k) {
    int low = 0, high = 0;
    
    for (int i = 0; i < n; i++) {
        high += boards[i];
        if (low < boards[i]) {
            low = boards[i];
        }
    }
    
    int result = high;
    
    while (low <= high) {
        int mid = (low + high) / 2;
        
        if (canPaint(boards, n, k, mid)) {
            result = mid;
            high = mid - 1;
        } else {
            low = mid + 1;
        }
    }
    
    return result;
}

int main() {
    int n, k;
    scanf("%d %d", &n, &k);
    
    int boards[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &boards[i]);
    }
    
    printf("%d\n", minTimeToPaintBoards(boards, n, k));
    
    return 0;
}
