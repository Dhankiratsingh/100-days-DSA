#include <stdio.h>
#include <stdlib.h>

#define MAX 100005

int visited[MAX];
int adj[MAX][100]; 
int size[MAX];     

int queue[MAX];

int main() {
    int n, m;
    scanf("%d %d", &n, &m);

    for (int i = 1; i <= n; i++) {
        visited[i] = 0;
        size[i] = 0;
    }

    for (int i = 0; i < m; i++) {
        int u, v;
        scanf("%d %d", &u, &v);

        adj[u][size[u]++] = v;
        adj[v][size[v]++] = u;
    }


    int front = 0, rear = 0;

    queue[rear++] = 1;
    visited[1] = 1;

    while (front < rear) {
        int node = queue[front++];

        for (int i = 0; i < size[node]; i++) {
            int neighbor = adj[node][i];
            if (!visited[neighbor]) {
                visited[neighbor] = 1;
                queue[rear++] = neighbor;
            }
        }
    }

  
    for (int i = 1; i <= n; i++) {
        if (!visited[i]) {
            printf("NOT CONNECTED");
            return 0;
        }
    }

    printf("CONNECTED");
    return 0;
}
